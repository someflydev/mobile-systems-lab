{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mobile-systems-lab.local/contracts/UNIFIED_METRICS.schema.json",
  "title": "UNIFIED_METRICS",
  "description": "Normalized cross-platform benchmark output derived from BENCHMARK_RESULT files.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "benchmark_id",
    "lab_id",
    "scenario",
    "normalization_context",
    "platform_metrics",
    "comparative_summary",
    "regression_alerts"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "unified_metrics.v1"
    },
    "benchmark_id": {
      "type": "string"
    },
    "lab_id": {
      "type": "string",
      "pattern": "^LAB_[0-9]{2}(_[A-Z0-9_]+)?$"
    },
    "scenario": {
      "type": "string",
      "enum": [
        "idle",
        "accelerometer_only",
        "gps_only",
        "combined_sensors",
        "background_resume"
      ]
    },
    "normalization_context": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "device_class",
        "os_version_locked",
        "build_type",
        "sample_window_sec",
        "winsorization_pct",
        "unit_conventions"
      ],
      "properties": {
        "device_class": {
          "type": "string",
          "enum": ["low", "mid", "high"]
        },
        "os_version_locked": {
          "type": "boolean"
        },
        "build_type": {
          "type": "string",
          "enum": ["debug", "profile", "release"]
        },
        "sample_window_sec": {
          "type": "integer",
          "minimum": 10,
          "maximum": 3600
        },
        "winsorization_pct": {
          "type": "number",
          "minimum": 0,
          "maximum": 20
        },
        "unit_conventions": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "time",
            "memory",
            "cpu",
            "throughput_accel",
            "throughput_gps",
            "battery"
          ],
          "properties": {
            "time": { "type": "string", "const": "ms" },
            "memory": { "type": "string", "const": "MB" },
            "cpu": { "type": "string", "const": "pct" },
            "throughput_accel": { "type": "string", "const": "events_per_sec" },
            "throughput_gps": { "type": "string", "const": "events_per_min" },
            "battery": { "type": "string", "const": "pct_per_hour" }
          }
        }
      }
    },
    "platform_metrics": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "platform",
          "cold_start_ms_p95",
          "warm_start_ms_p95",
          "memory_idle_mb_p95",
          "memory_streaming_mb_p95",
          "cpu_idle_pct_p95",
          "cpu_accel_pct_p95",
          "cpu_gps_pct_p95",
          "jank_rate_pct",
          "frame_time_p95_ms",
          "accel_throughput_eps_p50",
          "gps_throughput_epm_p50",
          "battery_drain_pct_per_hour",
          "background_reliability_pct",
          "config_load_ms_p95",
          "score"
        ],
        "properties": {
          "platform": {
            "type": "string",
            "enum": [
              "kotlin_android",
              "swift_ios",
              "flutter",
              "react_native"
            ]
          },
          "cold_start_ms_p95": { "type": "number", "minimum": 0 },
          "warm_start_ms_p95": { "type": "number", "minimum": 0 },
          "memory_idle_mb_p95": { "type": "number", "minimum": 0 },
          "memory_streaming_mb_p95": { "type": "number", "minimum": 0 },
          "cpu_idle_pct_p95": { "type": "number", "minimum": 0, "maximum": 100 },
          "cpu_accel_pct_p95": { "type": "number", "minimum": 0, "maximum": 100 },
          "cpu_gps_pct_p95": { "type": "number", "minimum": 0, "maximum": 100 },
          "jank_rate_pct": { "type": "number", "minimum": 0, "maximum": 100 },
          "frame_time_p95_ms": { "type": "number", "minimum": 0 },
          "accel_throughput_eps_p50": { "type": "number", "minimum": 0 },
          "gps_throughput_epm_p50": { "type": "number", "minimum": 0 },
          "battery_drain_pct_per_hour": { "type": "number", "minimum": 0, "maximum": 100 },
          "background_reliability_pct": { "type": "number", "minimum": 0, "maximum": 100 },
          "config_load_ms_p95": { "type": "number", "minimum": 0 },
          "score": {
            "type": "number",
            "minimum": 0,
            "maximum": 100,
            "description": "Composite score for quick comparison; not a replacement for raw metrics."
          }
        }
      }
    },
    "comparative_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "best_cold_start",
        "best_memory_idle",
        "best_frame_stability",
        "best_battery",
        "best_background_reliability",
        "overall_rank"
      ],
      "properties": {
        "best_cold_start": { "$ref": "#/$defs/platform_ref" },
        "best_memory_idle": { "$ref": "#/$defs/platform_ref" },
        "best_frame_stability": { "$ref": "#/$defs/platform_ref" },
        "best_battery": { "$ref": "#/$defs/platform_ref" },
        "best_background_reliability": { "$ref": "#/$defs/platform_ref" },
        "overall_rank": {
          "type": "array",
          "minItems": 4,
          "maxItems": 4,
          "items": {
            "$ref": "#/$defs/platform_ref"
          }
        }
      }
    },
    "regression_alerts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "platform",
          "metric",
          "baseline_value",
          "current_value",
          "delta_pct",
          "severity"
        ],
        "properties": {
          "platform": {
            "type": "string",
            "enum": [
              "kotlin_android",
              "swift_ios",
              "flutter",
              "react_native"
            ]
          },
          "metric": {
            "type": "string"
          },
          "baseline_value": { "type": "number" },
          "current_value": { "type": "number" },
          "delta_pct": { "type": "number" },
          "severity": {
            "type": "string",
            "enum": ["warning", "critical"]
          }
        }
      }
    }
  },
  "$defs": {
    "platform_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["platform", "value"],
      "properties": {
        "platform": {
          "type": "string",
          "enum": [
            "kotlin_android",
            "swift_ios",
            "flutter",
            "react_native"
          ]
        },
        "value": {
          "type": "number"
        }
      }
    }
  }
}
