{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mobile-systems-lab.local/contracts/BENCHMARK_RESULT.schema.json",
  "title": "BENCHMARK_RESULT",
  "description": "Raw per-run benchmark capture for one platform and one lab scenario.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "benchmark_id",
    "lab_id",
    "platform",
    "timestamp_utc",
    "run_context",
    "protocol",
    "metrics",
    "tooling",
    "summary"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "benchmark_result.v1"
    },
    "benchmark_id": {
      "type": "string",
      "minLength": 6
    },
    "lab_id": {
      "type": "string",
      "pattern": "^LAB_[0-9]{2}(_[A-Z0-9_]+)?$"
    },
    "platform": {
      "type": "string",
      "enum": [
        "kotlin_android",
        "swift_ios",
        "flutter",
        "react_native"
      ]
    },
    "timestamp_utc": {
      "type": "string",
      "format": "date-time"
    },
    "run_context": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "device_id",
        "device_model",
        "device_class",
        "os_name",
        "os_version",
        "build_type",
        "thermal_state",
        "battery_pct_start",
        "battery_pct_end"
      ],
      "properties": {
        "device_id": {
          "type": "string"
        },
        "device_model": {
          "type": "string"
        },
        "device_class": {
          "type": "string",
          "enum": ["low", "mid", "high"]
        },
        "os_name": {
          "type": "string",
          "enum": ["android", "ios"]
        },
        "os_version": {
          "type": "string"
        },
        "build_type": {
          "type": "string",
          "enum": ["debug", "profile", "release"]
        },
        "thermal_state": {
          "type": "string",
          "enum": ["nominal", "fair", "serious", "critical", "unknown"]
        },
        "battery_pct_start": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "battery_pct_end": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        }
      }
    },
    "protocol": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "cold_start_runs",
        "warm_start_runs",
        "sensor_stream_duration_sec",
        "idle_window_sec",
        "sample_interval_ms",
        "gps_enabled",
        "accelerometer_enabled",
        "background_window_sec"
      ],
      "properties": {
        "cold_start_runs": {
          "type": "integer",
          "minimum": 1,
          "maximum": 20
        },
        "warm_start_runs": {
          "type": "integer",
          "minimum": 1,
          "maximum": 20
        },
        "sensor_stream_duration_sec": {
          "type": "integer",
          "minimum": 10,
          "maximum": 1800
        },
        "idle_window_sec": {
          "type": "integer",
          "minimum": 10,
          "maximum": 600
        },
        "sample_interval_ms": {
          "type": "integer",
          "minimum": 50,
          "maximum": 10000
        },
        "gps_enabled": {
          "type": "boolean"
        },
        "accelerometer_enabled": {
          "type": "boolean"
        },
        "background_window_sec": {
          "type": "integer",
          "minimum": 0,
          "maximum": 1800
        }
      }
    },
    "metrics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "cold_start_ms_samples",
        "warm_start_ms_samples",
        "memory_idle_mb_samples",
        "memory_sensor_stream_mb_samples",
        "cpu_idle_pct_samples",
        "cpu_accel_pct_samples",
        "cpu_gps_pct_samples",
        "frame_jank",
        "sensor_throughput",
        "battery",
        "background_execution",
        "config_load_latency_ms_samples"
      ],
      "properties": {
        "cold_start_ms_samples": {
          "$ref": "#/$defs/number_samples"
        },
        "warm_start_ms_samples": {
          "$ref": "#/$defs/number_samples"
        },
        "memory_idle_mb_samples": {
          "$ref": "#/$defs/number_samples"
        },
        "memory_sensor_stream_mb_samples": {
          "$ref": "#/$defs/number_samples"
        },
        "cpu_idle_pct_samples": {
          "$ref": "#/$defs/percent_samples"
        },
        "cpu_accel_pct_samples": {
          "$ref": "#/$defs/percent_samples"
        },
        "cpu_gps_pct_samples": {
          "$ref": "#/$defs/percent_samples"
        },
        "frame_jank": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "total_frames",
            "jank_frames",
            "jank_rate_pct",
            "frame_time_p95_ms"
          ],
          "properties": {
            "total_frames": {
              "type": "integer",
              "minimum": 0
            },
            "jank_frames": {
              "type": "integer",
              "minimum": 0
            },
            "jank_rate_pct": {
              "type": "number",
              "minimum": 0,
              "maximum": 100
            },
            "frame_time_p95_ms": {
              "type": "number",
              "minimum": 0
            }
          }
        },
        "sensor_throughput": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "accelerometer_events_per_sec",
            "gps_events_per_min"
          ],
          "properties": {
            "accelerometer_events_per_sec": {
              "$ref": "#/$defs/number_samples"
            },
            "gps_events_per_min": {
              "$ref": "#/$defs/number_samples"
            }
          }
        },
        "battery": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "estimated_drain_pct_per_hour",
            "delta_pct_during_run"
          ],
          "properties": {
            "estimated_drain_pct_per_hour": {
              "type": "number",
              "minimum": 0,
              "maximum": 100
            },
            "delta_pct_during_run": {
              "type": "number",
              "minimum": -5,
              "maximum": 100
            }
          }
        },
        "background_execution": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "attempts",
            "successful_resumes",
            "reliability_pct"
          ],
          "properties": {
            "attempts": {
              "type": "integer",
              "minimum": 0
            },
            "successful_resumes": {
              "type": "integer",
              "minimum": 0
            },
            "reliability_pct": {
              "type": "number",
              "minimum": 0,
              "maximum": 100
            }
          }
        },
        "config_load_latency_ms_samples": {
          "$ref": "#/$defs/number_samples"
        }
      }
    },
    "tooling": {
      "type": "object",
      "additionalProperties": false,
      "required": ["collector_version", "commands_executed", "log_artifacts"],
      "properties": {
        "collector_version": {
          "type": "string"
        },
        "commands_executed": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        },
        "log_artifacts": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["type", "path"],
            "properties": {
              "type": {
                "type": "string"
              },
              "path": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "cold_start_ms_p50",
        "cold_start_ms_p95",
        "warm_start_ms_p50",
        "memory_idle_mb_p50",
        "memory_streaming_mb_p50",
        "cpu_idle_pct_p50",
        "cpu_accel_pct_p50",
        "cpu_gps_pct_p50",
        "config_load_ms_p50"
      ],
      "properties": {
        "cold_start_ms_p50": { "type": "number", "minimum": 0 },
        "cold_start_ms_p95": { "type": "number", "minimum": 0 },
        "warm_start_ms_p50": { "type": "number", "minimum": 0 },
        "memory_idle_mb_p50": { "type": "number", "minimum": 0 },
        "memory_streaming_mb_p50": { "type": "number", "minimum": 0 },
        "cpu_idle_pct_p50": { "type": "number", "minimum": 0, "maximum": 100 },
        "cpu_accel_pct_p50": { "type": "number", "minimum": 0, "maximum": 100 },
        "cpu_gps_pct_p50": { "type": "number", "minimum": 0, "maximum": 100 },
        "config_load_ms_p50": { "type": "number", "minimum": 0 }
      }
    }
  },
  "$defs": {
    "number_samples": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "number"
      }
    },
    "percent_samples": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "number",
        "minimum": 0,
        "maximum": 100
      }
    }
  }
}
